{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/refresh-stats",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/regenerate-insights",
      "schedule": "0 4 * * *"
    }
  ]
}
