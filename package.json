{
  "name": "nexus-team-hub",
  "version": "0.1.0",
  "description": "Private desktop and web command center for competitive Valorant teams.",
  "author": "MainTez",
  "private": true,
  "main": "desktop/main.cjs",
  "nexus": {
    "appUrl": "https://molgarians-premier-hub.vercel.app",
    "desktopDownloadUrl": "https://github.com/MainTez/Valorant/releases/latest/download/Nexus-Team-Hub-Setup.exe"
  },
  "scripts": {
    "dev": "next dev",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000/desktop && electron .\"",
    "desktop:start": "electron .",
    "desktop:pack": "npm run build && electron-builder --win nsis --x64",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --no-warnings --test lib/vods.test.ts lib/auth/public-paths.test.ts lib/auth/vip.test.ts lib/routines/player-routines.test.ts lib/stats/tracker-score.test.ts lib/stats/match-moments.test.ts",
    "type-check": "tsc --noEmit"
  },
  "build": {
    "appId": "gg.nexus.teamhub",
    "productName": "Nexus Team Hub",
    "artifactName": "Nexus-Team-Hub-Setup.${ext}",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.469.0",
    "next": "15.1.11",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^2.15.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.6",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.1.6",
    "postcss": "^8.5.1",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3",
    "wait-on": "^9.0.5"
  }
}
