# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# HenrikDev Valorant API
# Get a key at https://docs.henrikdev.xyz
HENRIK_API_KEY=
HENRIK_REGION_DEFAULT=eu

# OpenRouter (hybrid AI insights)
# Free models at https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=Nexus Team Hub

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public website link for the Windows installer CTA.
NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL=https://github.com/MainTez/Valorant/releases/latest/download/Nexus-Team-Hub-Setup.exe
# Electron loads this URL. Use http://localhost:3000 for dev or your deployed app URL for packaged builds.
NEXUS_APP_URL=http://localhost:3000

# Spotify now playing
# Redirect URI in Spotify dashboard: http://localhost:3000/api/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# Cron (gate for /api/cron/*)
CRON_SECRET=change-me-to-a-long-random-string
